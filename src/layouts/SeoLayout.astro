---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  lang: "es" | "en";
  canonicalPath: string;
  alternatePathEs: string;
  alternatePathEn: string;
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description,
  lang,
  canonicalPath,
  alternatePathEs,
  alternatePathEn,
  structuredData,
} = Astro.props;

const baseUrl = Astro.url.origin;
const canonicalUrl = new URL(canonicalPath, Astro.url).toString();
const ogImageUrl = new URL("/og-image.png", Astro.url).toString();
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Diego Alarcon Inturias" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0c1325" />

    <title>{title}</title>

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={`${baseUrl}${alternatePathEs}`} />
    <link rel="alternate" hreflang="en" href={`${baseUrl}${alternatePathEn}`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/en/`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={lang === "es" ? "es_BO" : "en_US"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/logo-artic-fox.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />

    {
      structuredData && (
        <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      )
    }
  </head>
  <body class="bg-slate-950 text-slate-100 antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div
        class="absolute -top-36 -left-10 h-80 w-80 rounded-full bg-cyan-500/20 blur-3xl animate-drift-slower"
      >
      </div>
      <div
        class="absolute top-20 right-0 h-80 w-80 rounded-full bg-emerald-400/12 blur-3xl animate-float-slow"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/4 h-72 w-72 rounded-full bg-amber-300/10 blur-3xl animate-drift-slow"
      >
      </div>
      <div
        class="absolute inset-0 opacity-45"
        style="background-image: radial-gradient(circle at 1px 1px, rgba(148, 163, 184, 0.18) 1px, transparent 0); background-size: 24px 24px;"
      >
      </div>
    </div>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --identity-cyan: #5eead4;
    --identity-ink: #0c1325;
    --identity-amber: #fbbf24;
  }

  body {
    font-family: "Sora", ui-sans-serif, system-ui, sans-serif;
    background:
      radial-gradient(1300px circle at 0% 0%, rgba(45, 212, 191, 0.08), transparent 42%),
      radial-gradient(900px circle at 100% 5%, rgba(251, 191, 36, 0.08), transparent 35%),
      var(--identity-ink);
  }

  .font-title {
    font-family: "Space Grotesk", "Sora", ui-sans-serif, sans-serif;
    letter-spacing: -0.02em;
  }

  code,
  .font-mono-brand {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  ::selection {
    background: rgba(94, 234, 212, 0.35);
    color: #e2e8f0;
  }

  .portfolio-shell {
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    border: 1px solid rgba(148, 163, 184, 0.2);
    background: linear-gradient(145deg, rgba(15, 23, 42, 0.76), rgba(15, 23, 42, 0.45));
    backdrop-filter: blur(14px);
    box-shadow: 0 20px 50px -32px rgba(0, 0, 0, 0.65);
  }

  .portfolio-card {
    border-radius: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.2);
    background: rgba(15, 23, 42, 0.55);
    transition:
      transform 550ms ease,
      border-color 550ms ease,
      background-color 550ms ease;
  }

  .portfolio-card:hover {
    transform: translateY(-2px);
    border-color: rgba(103, 232, 249, 0.45);
    background: rgba(15, 23, 42, 0.75);
  }

  .portfolio-kicker {
    display: inline-flex;
    border-radius: 999px;
    border: 1px solid rgba(103, 232, 249, 0.35);
    background: rgba(34, 211, 238, 0.12);
    padding: 0.2rem 0.65rem;
    font-size: 0.69rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #a5f3fc;
  }

  .mesh-glow::before {
    content: "";
    position: absolute;
    inset: -25% auto auto -10%;
    width: 55%;
    height: 55%;
    border-radius: 9999px;
    background: radial-gradient(circle, rgba(45, 212, 191, 0.22), transparent 70%);
    pointer-events: none;
  }
</style>

